{
  "name": "sequence-bench",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter dashboard dev",
    "build": "pnpm --filter dashboard build",
    "lint": "pnpm --filter dashboard lint",
    "test": "pnpm test:ml-engine",
    "test:ml-engine": "cd apps/ml-engine && py -m pytest",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "apps/dashboard/**/*.{ts,tsx}": "eslint --fix"
  }
}
